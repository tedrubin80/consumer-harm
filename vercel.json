{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": "web",
  "framework": null,
  "redirects": [
    {
      "source": "/app",
      "destination": "https://consumer-harm-production.up.railway.app/",
      "permanent": false
    },
    {
      "source": "/app/:path*",
      "destination": "https://consumer-harm-production.up.railway.app/:path*",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Project", "value": "consumer-harm" }
      ]
    }
  ]
}
